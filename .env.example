# Server
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000
# Must match the browser origin (port) where you open the UI, or session/CORS breaks.
CLIENT_ORIGIN=http://localhost:5173

# Optional: if the API is not on :3000, set for Vite dev/preview proxy (repo root or client/.env)
# VITE_DEV_API_PROXY=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://watchtube:watchtube@localhost:5432/watchtube

# Sessions
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# =============================================================================
# Object storage (S3-compatible) — used for presigned PUT uploads + playback URLs
# =============================================================================
#
# Flow: server creates a presigned PUT URL (uses S3_* below). Browser PUTs the file
# there. After complete, playback URL = CDN_PUBLIC_BASE_URL + "/" + objectKey
# (object key is "{userId}/{videoId}" with no leading slash on the key).
#
# --- Local MinIO (see docker-compose.yml) ---
# Start MinIO, then ensure bucket + CORS exist (minio-init in compose, or MinIO console).
S3_REGION=us-east-1
S3_BUCKET=watchtube-videos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# API endpoint the *server* uses to sign requests (must be reachable from Node).
S3_ENDPOINT=http://localhost:9000
# Required for MinIO and many S3-compatible APIs (path-style: host/bucket/key).
S3_FORCE_PATH_STYLE=true
#
# URL prefix the *browser* uses to GET the uploaded file (no trailing slash).
# With path-style MinIO this is: http://<host>:<port>/<bucket-name>
# Must match S3_BUCKET so playback URL is: CDN_PUBLIC_BASE_URL + "/" + "{userId}/{videoId}"
CDN_PUBLIC_BASE_URL=http://localhost:9000/watchtube-videos
#
# If browser upload fails with CORS / network error: your CLIENT_ORIGIN (e.g. http://localhost:5174)
# must be allowed on the bucket. Update docker-compose minio-init AllowedOrigins, then
# `docker compose run --rm minio-init` (or set CORS in MinIO console → Buckets → CORS).
# Playback uses HTTP Range requests; minio-init exposes Content-Range / Accept-Ranges for that.
#
# --- AWS S3 ---
# Omit S3_ENDPOINT (or use regional https://s3.<region>.amazonaws.com). Set S3_FORCE_PATH_STYLE=false.
# CDN_PUBLIC_BASE_URL is often CloudFront origin URL, e.g. https://d111111abcdef8.cloudfront.net
#
# --- Cloudflare R2 ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
# CDN_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev  (or your custom domain for public reads)

# Optional: supertest uses a test DB
# DATABASE_URL=postgresql://watchtube:watchtube@localhost:5432/watchtube_test
