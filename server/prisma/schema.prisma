generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VideoStatus {
  PENDING_UPLOAD
  READY
  FAILED
}

enum VideoVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum VideoCategory {
  MUSIC
  GAMING
  EDUCATION
  ENTERTAINMENT
  NEWS
  SPORTS
  TECH
  LIFESTYLE
  OTHER
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  displayName  String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  videos        Video[]        @relation("UserVideos")
  comments      Comment[]
  likes         Like[]
  subscriptions Subscription[] @relation("Subscriber")
  subscribers   Subscription[] @relation("Channel")
}

model Video {
  id              String          @id @default(uuid()) @db.Uuid
  ownerId         String          @db.Uuid
  owner           User            @relation("UserVideos", fields: [ownerId], references: [id], onDelete: Cascade)
  title           String
  description     String          @default("")
  status          VideoStatus     @default(PENDING_UPLOAD)
  s3Key           String
  contentType     String
  playbackUrl     String?
  durationSeconds Int?
  visibility      VideoVisibility @default(PUBLIC)
  category        VideoCategory   @default(OTHER)
  viewCount       Int             @default(0)
  createdAt       DateTime        @default(now())
  publishedAt     DateTime?

  comments Comment[]
  likes    Like[]

  @@index([ownerId, createdAt])
  @@index([status, createdAt])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  videoId   String   @db.Uuid
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  parentId  String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([videoId, createdAt])
}

model Like {
  userId  String @db.Uuid
  videoId String @db.Uuid
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
}

model Subscription {
  subscriberId String @db.Uuid
  channelId    String @db.Uuid
  subscriber   User   @relation("Subscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  channel      User   @relation("Channel", fields: [channelId], references: [id], onDelete: Cascade)

  @@id([subscriberId, channelId])
  @@index([channelId])
}
